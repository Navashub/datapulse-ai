# ── DataPulse AI — Environment Configuration ──────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to Git.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/datapulse_db

# ── ChromaDB (local vector database) ─────────────────────────────────────────
CHROMA_PERSIST_DIRECTORY=./chroma_db
CHROMA_COLLECTION_NAME=datapulse_documents

# ── Ollama (local AI models) ──────────────────────────────────────────────────
# Make sure Ollama is running: `ollama serve`
# Pull the models first:
#   ollama pull llama3.2
#   ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── RAG Pipeline Tuning ───────────────────────────────────────────────────────
RAG_TOP_K=4
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false